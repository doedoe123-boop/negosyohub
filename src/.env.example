APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=marketplace
DB_USERNAME=laravel
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

APP_DOMAIN=localhost
ADMIN_PATH_TOKEN=
STORE_PATH_TOKEN=
REALTY_PATH_TOKEN=
LIPAT_BAHAY_PATH_TOKEN=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=memcached

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ──────────────────────────────────────────────────
# PayPal Payment Gateway
# ──────────────────────────────────────────────────
PAYMENTS_TYPE=paypal

# Set to "sandbox" for dev/testing, "live" for production
PAYPAL_ENV=sandbox

# ── Sandbox (development / testing) ───────────────
# Get these from https://developer.paypal.com/dashboard/ → Apps & Credentials → Sandbox
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=

# ── Production ────────────────────────────────────
# On your production server, override the three vars above:
# PAYPAL_ENV=live
# PAYPAL_CLIENT_ID=<your-live-client-id>
# PAYPAL_SECRET=<your-live-secret>

FRONTEND_URL=http://localhost:5173

# ── Cloudflare Turnstile ─────────────────────────
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── PayMongo ──────────────────────────────────────
PAYMONGO_PUBLIC_KEY=pk_test_
PAYMONGO_SECRET_KEY=sk_test_
PAYMONGO_WEBHOOK_SECRET_TEST=
PAYMONGO_WEBHOOK_SECRET_LIVE=

# ── Brevo Newsletter ─────────────────────────────
BREVO_API_KEY=
BREVO_NEWSLETTER_LIST_ID=
BREVO_BASE_URL=https://api.brevo.com/v3
